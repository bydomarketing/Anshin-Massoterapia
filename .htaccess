# ----------------------------------------------------------------------
# Anshin Massoterapia - Hostinger Configuration (.htaccess)
# ----------------------------------------------------------------------

# 1. Redirecionar para HTTPS (Forçar SSL)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# 2. Configurar SPA (React Router - Navegação interna)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteRule ^index\.html$ - [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-l
    RewriteRule . /index.html [L]
</IfModule>

# 3. Cabeçalhos de Segurança (Hardening)
<IfModule mod_headers.c>
    # Previne ataques de XSS e Sniffing
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    
    # HSTS (Habilite apenas após testar se o SSL está 100% ok)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    
    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content Security Policy (Ajustado para o seu projeto)
    # Atencao: Se voce usa fontes ou APIs externas, adicione os dominios aqui.
    Header set Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https: res.cloudinary.com images.unsplash.com; connect-src 'self' https:; frame-src 'self' https://www.google.com https://maps.google.com;"
</IfModule>

# 4. Melhores Práticas de Proteção
# Desabilitar listagem de diretórios
Options -Indexes

# Bloquear acesso a arquivos sensíveis (Git, Env, Package, Logs, etc)
<FilesMatch "^\.|\.(bak|conf|dist|fla|in[ci]|log|psd|sh|sql|sw[op]|env|example|json|lock|ts|tsx|md|config\.js)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Proibir execução de PHP na pasta de assets (Previne Injeção de Malware)
<FilesMatch "\.(php|php5|php4|php3|phtml|phpt|pl|py|cgi|sh|asp|aspx)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# 5. Configurar Cache para maior Performance (Acelerar site na Hostinger)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    
    # Imagens e Icones
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    
    # Fontes
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    
    # Scripts e Estilos (Vite já gera hashes, mas é seguro colocar 1 mes)
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# 6. Compactar arquivos (Gzip/Brotli)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>
